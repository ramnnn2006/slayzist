# Copy this file to .env and fill in your key.

# Default setup uses Groq (free, no local install needed).
# Get a key at https://console.groq.com
GROQ_API_KEY=gsk_...

# If you prefer OpenAI instead, set this and switch the llm line in college_assistant.py
# OPENAI_API_KEY=sk-...

# Ollama runs locally and needs no key, just `ollama pull llama3.2` first.
